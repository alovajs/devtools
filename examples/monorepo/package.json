{
  "name": "worma-demo-esm-monorepo",
  "type": "module",
  "private": true,
  "description": "Worma ESM monorepo example — each sub-package tests a single generator template",
  "scripts": {
    "gen:all": "pnpm -r exec worma gen -f",
    "start:alova": "pnpm --filter alova-app start",
    "start:axios": "pnpm --filter axios-app start",
    "start:fetch": "pnpm --filter fetch-app start",
    "start:ky": "pnpm --filter ky-app start",
    "start": "pnpm start:alova && pnpm start:axios && pnpm start:fetch && pnpm start:ky"
  },
  "devDependencies": {
    "wormajs": "workspace:*"
  }
}
