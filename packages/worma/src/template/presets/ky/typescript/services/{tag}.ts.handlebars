{{> comment}}
import type { Options } from 'ky';
import { kyInstance } from '../index';
import { buildPayload } from '../helper';
import type * as ComponentTypes from '../components';
{{#each tagedApis}}
import { {{{tagName}}}DefaultConfig } from '.';
{{/each}}

{{#each tagedApis}}
{{#each apis}}
type {{{name}}}Response = {{processType response @root.componentNames}};
type {{{name}}}ExtraConfig = Options & {
  {{#if pathParameters}}pathParams: {{processType pathParameters @root.componentNames}};
  {{/if}}{{#if queryParameters}}searchParams: {{processType queryParameters @root.componentNames}};
  {{/if}}{{#if requestBody}}json: {{processType requestBody @root.componentNames}};
  {{/if}}
};
{{> api-jsdoc}}
export function {{{name}}}(config: {{{name}}}ExtraConfig): Promise<{{{name}}}Response> {
  const { url, mergedConfig } = buildPayload('{{{path}}}', {{{tag}}}DefaultConfig, {{{name}}}.name, config);
  const resolvedPath = url.replace(/^\//, '');
  return kyInstance(resolvedPath, {
    method: '{{method}}',
    ...mergedConfig,
  }){{#if (eq response "Blob")}}.blob(){{else}}.json<{{{name}}}Response>(){{/if}} as Promise<{{{name}}}Response>;
}

{{/each}}
{{/each}}
