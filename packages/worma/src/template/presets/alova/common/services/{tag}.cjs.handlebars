{{> comment}}
const { alovaInstance } = require('../index');
const { buildPayload } = require('../helper');
const { {{currentTag.tagName}}DefaultConfig } = require('.');

{{#each tagedApis}}
{{#each apis}}
{{> api-jsdoc}}
function {{{name}}}(config) {
  const { url, data, mergedConfig } = buildPayload('{{{path}}}', {{{tag}}}DefaultConfig, {{{name}}}.name, config);
  return alovaInstance.Request({
    ...mergedConfig,
    url,
    data,
    method: '{{method}}',{{#if (eq response "Blob")}}
    blob: true,{{/if}}
  });
}

{{/each}}
{{/each}}
module.exports = {
  {{#each tagedApis}}
  {{#each apis}}
  {{{name}}},
  {{/each}}
  {{/each}}
};
