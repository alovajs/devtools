{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "paths": {
      "~/*": [
        "./typings/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "#/*": [
        "./*"
      ]
    },
    "resolveJsonModule": false,
    "types": [
      "vitest/globals"
    ],
    "esModuleInterop": true,
    "skipLibCheck": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*",
    "./*.ts",
    "typings/**/*.d.ts",
    "./scripts/**/*",
    "vitest.config.mts"
  ],
  "exclude": [
    "test/output/**/*"
  ]
}
