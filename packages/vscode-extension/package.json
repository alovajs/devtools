{
  "publisher": "worma",
  "name": "worma-vscode",
  "displayName": "Worma",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "description": "Generate and search APIs without API documentation any more",
  "author": "czhlin",
  "license": "MIT",
  "funding": "https://github.com/sponsors/czhlin",
  "homepage": "https://github.com/alovajs/devtools#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/alovajs/devtools.git"
  },
  "bugs": {
    "url": "https://github.com/alovajs/devtools/issues"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/czhlin"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension/index.js",
  "icon": "res/icon.png",
  "files": [
    "LICENSE",
    "dist/**",
    "res"
  ],
  "engines": {
    "node": ">=18",
    "vscode": "^1.89.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:package.json",
    "onView:myTreeView"
  ],
  "contributes": {
    "configuration": {
      "title": "Worma",
      "properties": {
        "worma.autoUpdate": {
          "markdownDescription": "Whether to automatically update APIs. Set to `false` to disable, `true` for default (every 5 minutes), or an object for detailed configuration.",
          "oneOf": [
            {
              "type": "boolean",
              "default": true
            },
            {
              "type": "object",
              "properties": {
                "launchEditor": {
                  "type": "boolean",
                  "default": false,
                  "description": "Update immediately when the editor launches."
                },
                "interval": {
                  "type": "number",
                  "default": 300000,
                  "description": "Auto-update interval in milliseconds."
                }
              },
              "additionalProperties": false
            }
          ],
          "default": true
        }
      }
    },
    "commands": [
      {
        "command": "worma.refresh",
        "category": "Worma",
        "title": "Generate APIs"
      },
      {
        "command": "worma.generateApi.force",
        "category": "Worma",
        "title": "Force Generate APIs"
      },
      {
        "command": "worma.create.config",
        "category": "Worma",
        "title": "Create worma config"
      },
      {
        "command": "worma.apiDocs.refresh",
        "title": "Refresh View",
        "icon": "$(refresh)"
      },
      {
        "command": "worma.snippetSearch.open",
        "title": "Open Snippet Search",
        "category": "Snippet Search"
      },
      {
        "command": "worma.snippetSearch.insert",
        "title": "Insert Snippet",
        "category": "Snippet Search"
      },
      {
        "command": "worma.snippetSearch.showHelp",
        "title": "Show Shortcut Help",
        "category": "Snippet Search"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "worma.apiDocs.refresh",
          "group": "navigation",
          "when": "view == api-docs-server-view"
        }
      ],
      "commandPalette": [
        {
          "command": "worma.snippetSearch.insert",
          "when": "editorTextFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "worma.snippetSearch.open",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus"
      }
    ],
    "icons": {
      "worma-icon-id": {
        "description": "alova icon",
        "default": {
          "fontPath": "./res/logo.ttf",
          "fontCharacter": "\\E64E"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "api-docs-sidebar",
          "title": "Worma",
          "icon": "res/logo.svg"
        }
      ]
    },
    "views": {
      "api-docs-sidebar": [
        {
          "icon": "res/icon.png",
          "id": "api-docs-server-view",
          "name": "Api Server",
          "type": "webview"
        },
        {
          "icon": "res/icon.png",
          "id": "api-docs-detail-view",
          "name": "Api Detail",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite -m vscode",
    "dev:web": "vite",
    "build": "vite build -m vscode && (pnpm run build:dts || true)",
    "build:dts": "dts-bundle-generator -o dist/extension/index.d.ts ext/index.ts --no-check --no-banner --project tsconfig.node.json",
    "build:handlers": "dts-bundle-generator -o typings/handlers.d.ts ext/handlers/index.ts --no-check --no-banner --project tsconfig.node.json",
    "buld:meta": "vscode-ext-gen --output ext/meta/generated.ts && eslint ext/meta/generated.ts --fix",
    "update": "run-p build:meta build:handlers",
    "lint": "eslint .",
    "lintf": "eslint . --fix",
    "vscode:prepublish": "nr build",
    "publish": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
    "pack": "vsce package --no-dependencies",
    "pack:pre": "vsce package --no-dependencies --pre-release",
    "test": "vitest",
    "test:e2e": "node ./e2e-out/index.js",
    "pretest:e2e": "rimraf e2e-out && tsc -p e2e",
    "test:unit": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "sizecheck": "npx vite-bundle-visualizer",
    "release:pre": "vsce publish --no-dependencies --pre-release && ovsx publish --no-dependencies --pre-release",
    "release": "vsce publish --no-dependencies && ovsx publish --no-dependencies"
  },
  "dependencies": {
    "@unhead/vue": "catalog:frontend",
    "@vicons/ionicons5": "catalog:frontend",
    "@vueuse/core": "catalog:frontend",
    "glob": "catalog:dev",
    "highlight.js": "catalog:frontend",
    "import-fresh": "catalog:dev",
    "nprogress": "catalog:frontend",
    "pinia": "catalog:frontend",
    "query-string": "catalog:frontend",
    "vue": "catalog:frontend",
    "vue-i18n": "catalog:frontend",
    "vue-router": "catalog:frontend"
  },
  "devDependencies": {
    "@czhlin/vite-plugin-vscode": "catalog:build",
    "@iconify-json/carbon": "catalog:dev",
    "@intlify/unplugin-vue-i18n": "catalog:build",
    "@jsonrpc-rx/client": "catalog:frontend",
    "@jsonrpc-rx/server": "catalog:frontend",
    "@shikijs/markdown-it": "catalog:build",
    "@tailwindcss/typography": "catalog:build",
    "@tailwindcss/vite": "catalog:build",
    "@tomjs/tsconfig": "catalog:dev",
    "@tomjs/vscode-webview": "catalog:frontend",
    "@types/chai": "catalog:types",
    "@types/chai-jest-snapshot": "catalog:types",
    "@types/fs-extra": "catalog:types",
    "@types/markdown-it-link-attributes": "catalog:types",
    "@types/mocha": "catalog:types",
    "@types/node": "catalog:types",
    "@types/nprogress": "catalog:types",
    "@types/sinon": "catalog:types",
    "@types/vscode": "^1.89.0",
    "@types/vscode-webview": "catalog:types",
    "@vitejs/plugin-vue": "catalog:build",
    "@vitejs/plugin-vue-jsx": "catalog:build",
    "@vscode/test-electron": "catalog:dev",
    "@vscode/vsce": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "chai": "catalog:dev",
    "chai-jest-snapshot": "catalog:dev",
    "chalk": "catalog:dev",
    "fs-extra": "catalog:dev",
    "markdown-it-link-attributes": "catalog:build",
    "mocha": "catalog:dev",
    "naive-ui": "catalog:frontend",
    "ovsx": "catalog:dev",
    "pino": "catalog:dev",
    "reactive-vscode": "catalog:frontend",
    "sinon": "catalog:dev",
    "tailwindcss": "catalog:build",
    "typescript": "catalog:dev",
    "unplugin-auto-import": "catalog:build",
    "unplugin-vue-components": "catalog:build",
    "unplugin-vue-markdown": "catalog:build",
    "unplugin-vue-router": "catalog:build",
    "vite": "catalog:build",
    "vite-bundle-visualizer": "catalog:build",
    "vite-plugin-inspect": "catalog:build",
    "vite-plugin-vue-devtools": "catalog:build",
    "vite-plugin-vue-layouts": "catalog:build",
    "vscode-ext-gen": "catalog:build",
    "vue-tsc": "catalog:dev",
    "wormajs": "workspace:*"
  }
}
